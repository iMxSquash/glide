{
    "name": "glide",
    "version": "1.1.2",
    "license": "GPL-3.0-or-later",
    "private": true,
    "type": "module",
    "workspaces": [
        "apps/*",
        "libs/*"
    ],
    "scripts": {
        "dev:server": "nx serve server-electron",
        "dev:client": "nx serve client-pwa",
        "dev:signaling": "nx serve signaling",
        "build:server": "nx build server-electron",
        "build:client": "nx build client-pwa",
        "build:signaling": "nx build signaling",
        "build:all": "npm run build:client && npm run build:server",
        "dist:win": "npm run build:all && cd apps/server-electron && npm run dist",
        "dist:mac": "npm run build:all && cd apps/server-electron && npm run dist:mac",
        "setup:autostart": "node scripts/setup-autostart.cjs enable",
        "remove:autostart": "node scripts/setup-autostart.cjs disable",
        "lint": "eslint ."
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@nx/react": "^22.4.5",
        "@nx/vite": "^22.4.5",
        "@nx/workspace": "^23.0.1",
        "eslint": "^10.6.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "globals": "^17.7.0",
        "nx": "^22.4.5",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.63.0"
    }
}
