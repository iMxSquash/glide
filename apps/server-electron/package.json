{
    "name": "server-electron",
    "version": "1.1.1",
    "description": "Glide remote PC control server",
    "author": "Glide",
    "private": true,
    "main": "dist/src/main.js",
    "scripts": {
        "dev": "tsc && electron .",
        "build": "tsc",
        "dist": "electron-builder --win",
        "dist:mac": "electron-builder --mac"
    },
    "dependencies": {
        "@glide/shared-types": "1.0.0",
        "@nut-tree-fork/nut-js": "^4.2.2",
        "loudness": "^0.4.2",
        "qrcode": "^1.5.4",
        "socket.io-client": "^4.8.1"
    },
    "devDependencies": {
        "@types/node": "^22.12.8",
        "@types/qrcode": "^1.5.6",
        "electron": "35.7.5",
        "electron-builder": "^26.7.0",
        "typescript": "^5.8.3"
    },
    "build": {
        "appId": "com.glide.remote",
        "productName": "Glide",
        "win": {
            "target": "nsis",
            "icon": "assets/icon.ico"
        },
        "mac": {
            "target": "dmg",
            "category": "public.app-category.utilities"
        },
        "asarUnpack": [
            "**/node_modules/loudness/**"
        ],
        "files": [
            "dist/**/*",
            "assets/**/*",
            "package.json"
        ],
        "directories": {
            "output": "out"
        }
    }
}
