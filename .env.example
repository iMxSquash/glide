# Port HTTP du serveur de signaling (apps/signaling)
# Défaut si absent : 4000
PORT=4000

# URL publique de la PWA client, utilisée par le serveur Electron packagé
# pour générer le QR code de connexion.
# Défaut si absent : https://glide.elwen.dev (packagé) / http://localhost:4200 (dev)
GLIDE_PWA_URL=https://glide.elwen.dev

# URL publique du serveur de signaling WebRTC, utilisée par le serveur Electron
# packagé pour se connecter au bon serveur de signaling.
# Défaut si absent : https://glide-signaling.onrender.com (packagé) / http://localhost:4000 (dev)
GLIDE_SIGNALING_URL=https://glide-signaling.onrender.com
